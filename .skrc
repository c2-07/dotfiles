# Layout
--height=45%
--layout=reverse
--border=rounded

# UI
--info=inline-right
--prompt="❯ "
--pointer="▶"
--marker="✓"
--scrollbar=""

# Preview
--preview='
if [ -d {} ]; then
    eza --tree --level=2 --color=always {}
else
    bat --style=numbers --color=always {}
fi
'
--preview-window=right:55%,border-left

# Keybindings
--bind=ctrl-/:toggle-preview
--bind=ctrl-u:preview-half-page-up
--bind=ctrl-d:preview-half-page-down

# Colors (Gruvbox)
--color=bg:#1d2021,bg+:#32302f
--color=fg:#ebdbb2,fg+:#fbf1c7
--color=hl:#fabd2f,hl+:#fe8019
--color=pointer:#83a598
--color=marker:#b8bb26
--color=prompt:#8ec07c
--color=header:#928374
